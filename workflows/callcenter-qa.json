{
  "name": "callcenter-qa",
  "description": "Full first-slice pipeline: ingest -> redact -> transcribe -> prosody -> classify -> evaluate (script adherence).",
  "version": "0.0.1",
  "phases": [
    {"id": "ingest-1", "name": "Ingest", "type": "audio_ingest", "depends_on": [], "subscribes_to": [],
     "audio_ingest": {"min_seconds": 8.0}},
    {"id": "redact-1", "name": "Redact", "type": "audio_redaction", "depends_on": ["ingest-1"], "subscribes_to": ["ingest-1"],
     "audio_redaction": {"require_ner": true, "min_mean_word_probability": 0.30, "pad_seconds": 0.25}},
    {"id": "transcribe-1", "name": "Transcribe", "type": "transcription", "depends_on": ["redact-1"], "subscribes_to": ["redact-1"]},
    {"id": "prosody-1", "name": "Prosody", "type": "prosody", "depends_on": ["redact-1", "transcribe-1"], "subscribes_to": ["redact-1", "transcribe-1"]},
    {"id": "classify-1", "name": "Classify", "type": "call_path_classify", "depends_on": ["transcribe-1"], "subscribes_to": ["transcribe-1"],
     "call_path_classify": {"call_path": "newplan_esign", "contract_path": "contracts/callcenter-newplan-esign.json"}},
    {"id": "evaluate-1", "name": "Evaluate", "type": "phase_ledger", "depends_on": ["classify-1", "transcribe-1", "prosody-1"], "subscribes_to": ["classify-1", "transcribe-1", "prosody-1"]}
  ]
}
