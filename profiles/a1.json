    {
      "id": "deal",
      "primitive": "deal_detect",
      "tier": "soft",
      "_delivery_detect_note": "Close signal: the customer gives a callback/delivery NUMBER near the end of the call. NUMBER categories only (an address mention is excluded — refusing customers also state addresses); final-fraction gate discriminates a real close (~89% in the labelled sale) from a mid-call number (~66% in a give-up). Tuned on one confirmed sale — widen the labelled set before trusting broadly.",
      "delivery_detect": {
        "channel": "customer",
        "slot_categories": [
          "PHONE_OR_ID",
          "NUMERIC_RUN",
          "MULTI"
        ],
        "min_fraction": 0.8,
        "_customer_phrases_note": "Fix #2 soft-close: the customer DIRECTS the delivery (a place/time for the courier) in the closing portion. Separates a grudging soft-close from a give-up; tuned on one confirmed sale, re-tunable.",
        "customer_phrases": [
          "на работа",
          "фирма",
          "от дома",
          "часа тръгвам",
          "може да ме открие"
        ],
        "customer_min_fraction": 0.3
      }
    },
    {
      "id": "path",
      "primitive": "path_select",
      "tier": "soft"
    },
    {
      "id": "objection_effort",
      "primitive": "judge_check",
      "tier": "soft",
      "require_customer_quote": true,
      "question": "Did the agent make a real effort to rebut the customer's objection and keep selling? Answer met=true ONLY if, after the customer pushed back or hesitated, the agent gave a concrete counter-argument (price/benefit/reassurance) and continued trying to close. If the agent accepted the refusal, went quiet, moved on, or wrapped up ('дочуване'/'приятен ден') without countering, answer met=false."
    },
